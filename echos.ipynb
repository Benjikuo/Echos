    "class TiltRotorDynamics2D:\n",
    "    def __init__(self, mass=1.8, drag=0.6, max_speed=3.0):\n",
    "        self.mass, self.drag, self.max_speed = mass, drag, max_speed\n",
    "        self.velocity = np.zeros(2)\n",
    "        self.yaw_rate = 0.0\n",
    "    def reset(self):\n",
    "        self.velocity = np.zeros(2); self.yaw_rate = 0.0\n",
    "    def step(self, pos, yaw, action, dt=0.1):\n",
    "        thrust_cmd, yaw_cmd = action\n",
    "        target_rate = yaw_cmd * 3.0\n",
    "        self.yaw_rate += (target_rate - self.yaw_rate) * 0.3\n",
    "        next_yaw = yaw + self.yaw_rate * dt\n",
    "        force = thrust_cmd * 15.0\n",
    "        tv = np.array([math.cos(next_yaw), math.sin(next_yaw)]) * force\n",
    "        spd = np.linalg.norm(self.velocity)\n",
    "        accel = (tv - self.drag * self.velocity * spd) / self.mass\n",
    "        self.velocity += accel * dt\n",
    "        spd = np.linalg.norm(self.velocity)\n",
    "        if spd > self.max_speed:\n",
    "            self.velocity *= self.max_speed / spd\n",
    "        return pos + self.velocity * dt, next_yaw\n",
    "\n",
    "\n",
    "class MazeGenerator:\n",
    "    def __init__(self, width=12.0, height=9.0):\n",
    "        self.width, self.height = width, height\n",
    "        self.walls = []; self.wall_materials = {}; self.scout_waypoints = []\n",
    "\n",
    "    def generate(self, seed=None):\n",
    "        if seed is not None: np.random.seed(seed)\n",
    "        self.walls = []; self.wall_materials = {}\n",
    "        t = 0.3\n",
    "        outer = Polygon([(-t,-t),(self.width+t,-t),(self.width+t,self.height+t),(-t,self.height+t)])\n",
    "        inner = Polygon([(0,0),(self.width,0),(self.width,self.height),(0,self.height)])\n",
    "        self._add_poly(outer.difference(inner), 'concrete')\n",
    "        self._add_poly(Polygon([(2.5,0),(3.0,0),(3.0,5.0),(2.5,5.0)]), 'concrete')\n",
    "        self._add_poly(Polygon([(5.5,4),(6.0,4),(6.0,9),(5.5,9)]), 'concrete')\n",
    "        self._add_poly(Polygon([(8.0,0),(8.5,0),(8.5,5.0),(8.0,5.0)]), 'concrete')\n",
    "        self._add_poly(Polygon([(4.3,6.3),(5.0,6.3),(4.6,7.0)]), 'rubble')\n",
    "        self._add_poly(Polygon([(7.3,6.3),(8.0,6.3),(8.0,7.1),(7.3,7.1)]), 'metal')\n",
    "        self._add_poly(Polygon([(4.3,2.2),(5.0,2.2),(5.0,2.8),(4.3,2.8)]), 'drywall')\n",
    "        self.scout_waypoints = [np.array([1.5,7.0]),np.array([4.2,7.0]),np.array([4.2,2.0]),\n",
    "                                np.array([7.2,2.0]),np.array([7.2,7.0]),np.array([10.0,7.0]),np.array([11.0,4.5])]\n",
    "        return self.walls, self.wall_materials\n",
    "\n",
    "    def _add_poly(self, poly, material):\n",
    "        if poly.geom_type == 'Polygon':\n",
    "            self.walls.append(poly); self.wall_materials[id(poly)] = material\n",
    "        elif poly.geom_type == 'MultiPolygon':\n",
    "            for p in poly.geoms:\n",
    "                self.walls.append(p); self.wall_materials[id(p)] = material\n",
    "\n",
    "\n",
    "class AcousticRayTracer:\n",
    "    def __init__(self, walls, wall_materials):\n",
    "        self.walls = walls; self.wall_materials = wall_materials\n",
    "        self._segments = []\n",
    "        for wall in walls:\n",
    "            coords = list(wall.exterior.coords)\n",
    "            for i in range(len(coords)-1):\n",
    "                self._segments.append((np.array(coords[i],dtype=float), np.array(coords[i+1],dtype=float), wall))\n",
    "\n",
    "    def trace_ray(self, origin, direction, max_range=10.0):\n",
    "        origin = np.array(origin, dtype=float)\n",
    "        direction = np.array(direction, dtype=float)\n",
    "        nrm = np.linalg.norm(direction)\n",
    "        if nrm < 1e-10: return max_range, None, None\n",
    "        direction = direction / nrm\n",
    "        nearest_t, nearest_mat, nearest_pt = max_range, None, None\n",
    "        for seg_a, seg_b, wall in self._segments:\n",
    "            BAx, BAy = seg_b[0]-seg_a[0], seg_b[1]-seg_a[1]\n",
    "            AOx, AOy = seg_a[0]-origin[0], seg_a[1]-origin[1]\n",
    "            denom = direction[0]*(-BAy) - direction[1]*(-BAx)\n",
    "            if abs(denom) < 1e-10: continue\n",
    "            t = (AOx*(-BAy) - AOy*(-BAx)) / denom\n",
    "            s = (direction[0]*AOy - direction[1]*AOx) / denom\n",
    "            if t > 0.01 and -0.001 <= s <= 1.001 and t < nearest_t:\n",
    "                nearest_t = t\n",
    "                nearest_mat = self.wall_materials.get(id(wall), 'concrete')\n",
    "                nearest_pt = origin + direction * t\n",
    "        return nearest_t, nearest_mat, nearest_pt\n",
    "\n",
    "    def trace_beam(self, origin, yaw, mode='throw', num_rays=5, max_range=10.0):\n",
    "        beam = AcousticBeam()\n",
    "        half = beam.half_angle(mode)\n",
    "        results = []\n",
    "        for a_off in np.linspace(-half, half, num_rays):\n",
    "            d, mat, pt = self.trace_ray(origin, np.array([math.cos(yaw+a_off), math.sin(yaw+a_off)]), max_range)\n",
    "            results.append({'distance': d, 'material_name': mat, 'gain': beam.gain(abs(a_off), mode),\n",
    "                           'angle_offset': float(a_off), 'hit_point': pt})\n",
    "        return results\n",
    "\n",
    "\n",
    "class SfcwSensor:\n",
    "    def __init__(self, sfcw, beam, ray_tracer, noise_std=0.01):\n",
    "        self.sfcw = sfcw; self.beam = beam; self.ray_tracer = ray_tracer; self.noise_std = noise_std\n",
    "\n",
    "    def sweep(self, origin, yaw, mode='throw', num_rays=5, max_range=10.0):\n",
    "        rays = self.ray_tracer.trace_beam(origin, yaw, mode, num_rays, max_range)\n",
    "        results = []\n",
    "        for ray in rays:\n",
    "            dist, mat_name, gain = ray['distance'], ray['material_name'], ray['gain']\n",
    "            if mat_name is not None and dist < max_range:\n",
    "                mat = MaterialDb.get(mat_name)\n",
    "                phases, amps, snr = self.sfcw.simulate_reflection(dist, mat['freq_response'], mat['reflection_coeff'], self.noise_std)\n",
    "                amps = amps * gain\n",
    "                sfcw_r, prec = self.sfcw.range_from_phases_with_tof(phases, dist, amps)\n",
    "                obs = amps / (amps.max() + 1e-10)\n",
    "                id_name, id_c = MaterialDb.identify(obs)\n",
    "                results.append({'true_distance': dist, 'sfcw_range': sfcw_r, 'precision': prec,\n",
    "                               'phases': phases, 'amplitudes': amps, 'snr_db': 10.*np.log10(np.mean(snr)+1e-10),\n",
    "                               'material_true': mat_name, 'material_id': id_name, 'material_conf': id_c,\n",
    "                               'angle_offset': ray['angle_offset'], 'gain': gain, 'hit_point': ray['hit_point']})\n",
    "            else:\n",
    "                results.append({'true_distance': max_range, 'sfcw_range': max_range, 'precision': max_range*0.1,\n",
    "                               'phases': None, 'amplitudes': None, 'snr_db': -20.0, 'material_true': None,\n",
    "                               'material_id': 'open', 'material_conf': 0.0, 'angle_offset': ray['angle_offset'],\n",
    "                               'gain': gain, 'hit_point': None})\n",
    "        return results\n",
    "\n",
    "\n",
    "class PathBReceiver:\n",
    "    def __init__(self, source_db=80.0, noise_floor_db=35.0):\n",
    "        self.source_db = source_db; self.noise_floor_db = noise_floor_db\n",
    "    def compute_snr(self, uav_pos, survivor_pos, velocity=np.zeros(2)):\n",
    "        dist = max(0.1, float(np.linalg.norm(survivor_pos - uav_pos)))\n",
    "        return max(0.0, self.source_db - 20.*np.log10(dist) - self.noise_floor_db - float(np.linalg.norm(velocity))*2.0 + np.random.normal(0,0.5))\n",
    "\n",
    "print('Simulation module ready')"
   ],
